  "_comment_perplexity": "Enable Perplexity Sonar for real citation discovery. Get API key from https://www.perplexity.ai/settings/api",
  "citations": {
    "require_verification": true,
    "min_sources_per_article": 5,
    "max_source_age_years": 2,
